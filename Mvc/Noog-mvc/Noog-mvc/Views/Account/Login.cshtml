@using Noog_mvc.Models.Login
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    ViewData["MetaDescription"] = "Login Page";
    ViewData["Robots"] = "noindex,nofollow";

    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
<style>
    .btn-register {
        background-color: #A290BB;
        color: white;
    }

    .btn-equal {
        flex: 0 0 30%; /* Both buttons take roughly half the width */
        display: flex;
        align-items: center;
        justify-content: center;
        height: 45px; /* fixed height to match both buttons */
        border-radius: 10px;
        font-size: 12px; /* smaller text */
        padding: 2px 6px; /* reduce padding */
        line-height: 1.2; /* tighter line height */
        white-space: nowrap; /* keeps text on one line */
    }
    
    body {
        background-color: var(--primary-color);
        color: white;
	}
    h1 {
		text-align: center;
        margin-top: 2rem;
        font-size: 2rem;

    }
    form {
        background-color: white;
        color: black;
        padding: 20px;
        border-radius: 5px;
        max-width: 400px;
        margin: 2rem auto;
		box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        border-radius: 15px;
	}
</style>

<h1 class="text-center mb-4" style="font-weight: 200;">Login</h1>
<form asp-action="Login" method="post">
	<div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
		<span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group mb-4">
        <label asp-for="Password"></label>
		<input asp-for="Password" class="form-control" type="password" />
		<span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="mb-4 d-flex justify-content-between">
        <a asp-controller="Account" asp-action="Register" class="btn btn-register btn-equal btn-sm">Skapa konto</a>
        <input type="submit" value="Logga in" class="btn btn-primary btn-equal btn-sm" />
    </div>
</form>
