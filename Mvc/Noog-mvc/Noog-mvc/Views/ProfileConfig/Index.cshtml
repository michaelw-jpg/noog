@using Noog_mvc.Models.User
@model UserViewModel

@{
	Layout = "~/Views/Shared/_EmptyLayout.cshtml"; 
}

@{
    ViewData["Title"] = "ProfileConfig";
    var firstName = Model?.FirstName ;
    var lastName = Model?.LastName ;
    var email = Model?.Email;
    var profileImage = Model?.Image ?? Url.Content("~/images/profile.jpg");
    var password = Model?.Password ;
    var editIcon = Url.Content("~/images/Edit-icon.png");
    //TODO: add edit icon img
}


<style>
    .main-container {
        max-width: 100rem;
        margin: 80px auto;
        background-color: #fff;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.15);
        padding: 40px;
    }

    .header-section {
        text-align: left;
        margin-bottom: 30px;
    }

    h1 {
        color: #0074D9;
        margin: 0;
        font-size: 20px;
    }
    
    .content {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
    }

    .left-container {
        flex: 1 1 300px;
        min-width: 300px;
    }

    .right-container {
        flex: 0 0 220px; 
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .profile-img {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .profile-img img:first-child {
        max-width: 100%;
        max-height: 100%;
        width: clamp(200px, 5vw + 10px, 200px);
        height: auto;
        border-radius: 25px;
        object-fit: cover;
        display: flex;
        border: 3px solid var(--tertiary-color);
    }

    .edit-background {
        position: absolute;
        bottom: 10px;
        right: 10px;
        width: 60px;
        height: 60px;
        background-color: #0074D9;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s ease, background-color 0.2s ease;
    }

    .edit-background:hover {        
        background-color: #005fa3; 
    }

    .edit-background .edit-icon {
        width: 25px;
        height: 25px;
        display: block;
        object-fit: contain;
    }

    form {
        display: grid;
        grid-template-columns: 0.5fr 1fr;
        column-gap: 7rem;
        row-gap: 0.8rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 250px;
    }

    label {
        justify-self: end;
        margin-bottom: 5px;
        width: 120px;
    }

    input[type="text"],
    input[type="email"],
	input[type="password"] {
        width: 100%;
        max-width: 250px;
        padding: 10px;
        border-radius: 20px;
        background-color: #D9D9D9;
        border: 1px solid #D9D9D9;
        font-size: 15px;
        transition: 0.2s;
		box-shadow: 4px 5px 8px rgba(0,0,0,0.3);
    }

    input:focus {
        border-color: #0074D9;
        outline: none;
        box-shadow: 0 0 4px rgba(0,116,217,0.4);
    }

    .button-group {
        display: flex;
        gap: 20px;
        margin-top: 100px;
        grid-column: 2;
    }
    
    .save-button {
        background-color: #0074D9;
        color: white;
        border: none; 
        outline: none;
    }

    .save-button,
    .goBack-button {
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 150px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
    }

    .goBack-button {
        color: #EDEDED;
        background-color: #A290BB;
        transition: background 0.2s;
    }

    .goBack-button:hover {
        background-color: #8c79a6;
    }

    .save-button:hover {
        background-color: #005fa3;
    }
</style>


<div class="main-container">
    <div class="header-section">
        <h1>Account Settings</h1>
    </div>

    <div class="content">
        <div class="left-container">
            <form asp-controller="ProfileConfig" asp-action="Update" method="post">
                <div class="form-field">
                    <label for="Username"> Username: </label>
                    <input type="text" name="Username" value=""  />
                </div>

                <div class="form-field">
                    <label for="FirstName">First Name:</label>
                    <input type="text" id="FirstName" name="FirstName" value="@firstName" />
                </div>

                <div class="form-field">
                    <label for="LastName">Last Name:</label>
                    <input type="text" id="LastName" name="LastName" value="@lastName" />
                </div>

                <div class="form-field">
                    <label for="Email">Email:</label>
                    <input type="email" id="Email" name="Email" value="@email" />
                </div>

                <div class="form-field">
                    <label for="Password">Password:</label>
					<input type="password" id="Password" name="Password" value="" />
                </div>

                <div class="button-group">
                    <button class="save-button" type="submit">Save Changes</button>
                    <a class="goBack-button" asp-action="Dashboard" asp-controller="Dashboard">Go back</a>
                </div>
            </form>
        </div>

        <div class="right-container">
            <div class="profile-img">
                <img class="profile-card" src="@profileImage" alt="profileImg" />
                <div class="edit-background">
                    <img src="@editIcon" alt="Edit Icon" class="edit-icon" />
                </div>
            </div>
        </div>
    </div>
</div>