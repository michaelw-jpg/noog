@using Noog_mvc.Models.Dashboard
@using Noog_mvc.Models.DashboardSidebar
@model IEnumerable<ProjectGroupDto> 

<ul>
    <!-- Hardcoded -->
    <li>
        <a href="#" class="project-link">
            <img src="~/images/project-icon.png" alt="Icon" class="project-icon" />
            <span class="project-name">Project Alpha</span>
        </a>
    </li>
    <li>
        <a href="#" class="project-link">
            <img src="~/images/project-icon.png" alt="Icon" class="project-icon" />
            <span class="project-name">Project Beta</span>
        </a>
    </li>
    <!-- If api returns groupprojects -->
    @foreach (var group in Model)
    {
        var pgImage = string.IsNullOrEmpty(group.ImageUrl)
            ? Url.Content("~/images/project-icon.png")
            : group.ImageUrl;

        <li>
            <a href="@Url.Action("Details", "ProjectGroup", new { id = group.Id })" class="project-link">
                <img src="@pgImage" alt="@group.Title" class="project-icon" />
                <span class="project-name">@group.Title</span>
            </a>
        </li>
    }
</ul>
