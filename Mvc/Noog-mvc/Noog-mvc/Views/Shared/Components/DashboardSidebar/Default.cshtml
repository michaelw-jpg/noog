@using Noog_mvc.Models.Dashboard
@using Noog_mvc.Models.DashboardSidebar
@model IEnumerable<ProjectGroupDto> 

@{
    var currentId = ViewContext.RouteData.Values["id"]?.ToString();
    var hasActiveGroup = !string.IsNullOrEmpty(currentId);
}

<ul>
    <!-- Hardcoded -->
    <!-- If api returns groupprojects -->
    @foreach (var group in Model)
    {
        var pgImage = string.IsNullOrEmpty(group.ImageUrl)
            ? Url.Content("~/images/project-icon.png")
            : group.ImageUrl;

        var isActive = hasActiveGroup && (group.Id.ToString() == currentId);

        <li class="@(isActive ? "active" : "" )">
            <a href="@Url.Action("Index", "PGDashboard", new { id = group.Id })" class="project-link">
                <img src="@pgImage" alt="@group.Title" class="project-icon" />
                <span class="project-name">@group.Title</span>
            </a>
        </li>
    }
</ul>
