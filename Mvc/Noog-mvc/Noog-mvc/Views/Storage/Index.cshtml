@using Noog_mvc.Models.Storage
@model List<StorageSummary>

@{
    Layout = "~/Views/Shared/_PGDashboard.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/storage.css" asp-append-version="true" />
}
@{
    ViewData["Title"] = "Project Group Storage";
}


<section class="tile storage-tile">
    <article class="storage-article">
        <a asp-controller="ProjectGroup" asp-action="Index" asp-route-projectGroupId="@ViewBag.ProjectGroupId" class="back-arrow" aria-label="Back to Project Group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6" />
            </svg>
        </a>
        <h2 class="tile__title storage-tile-title">Storage</h2>
    </article>
    @if (!Model.Any())
    {
        <p>No summaries yet...</p>
    }
    <ol>
        @foreach (var summary in Model)
        {
            <li>
                <a asp-controller="Storage" asp-action="Summary" asp-route-projectGroupId="@ViewBag.ProjectGroupId" asp-route-id="@summary.Id">
                    <h3>@summary.Title</h3>
                    <span>@summary.CreatedAt.AddHours(1).ToString("dd/MM-yy HH:mm")</span>
                </a>
            </li>
        }
    </ol>
</section>
