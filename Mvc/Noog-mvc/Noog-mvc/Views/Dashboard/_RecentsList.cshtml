@using Noog_mvc.Models.Dashboard
@model IEnumerable<RecentActivityDto>

@functions {
    public string GetSourceIcon(string source)
    {
        return source switch
        {
            "Chat" => Url.Content("~/images/chat-icon.png"),
            "Meeting" or "Call" => Url.Content("~/images/meeting-icon.png"),
            "Storage" or "Summary" => Url.Content("~/images/storage-icon.png"),
            _ => Url.Content("~/images/default-icon.png")
        };
    }
}

<div class="recents-section">
    <h2 class="recents-title">Recents:</h2>
    <div class="recents-list">
        @if (!Model.Any())
        {
            <div class="recent-card">

                <div class="recent-center">No recent activities yet...</div>

            </div>
        }
        @foreach(var activity in Model)
        {
            <div class="recent-card">
                <div class="recent-left">
                    <img src="~/images/project-icon.png" class="project-icon" alt="Project" />
                    <span class="recents-project-name">@activity.ProjectGroupName</span>
                </div>
                <div class="recent-center">@activity.ActivityTitle</div>
                <div class="recent-right">
                    <img src="@GetSourceIcon(activity.Source)" alt="@activity.Source" class="recent-icon" />
                </div>
            </div>
		}
        
    </div>
</div>