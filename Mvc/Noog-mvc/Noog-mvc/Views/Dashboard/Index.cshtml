@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<section class="dashboard-main">
    <!-- Profile Card -->
    <div class="profile-card">
        <div class="profile-left">
            <h1 class="welcome-text">Welcome back</h1>
            <div class="username">Username</div>
        </div>
        <div class="profile-right">
            <button class="edit-button" aria-label="Edit Profile">
                <svg viewBox="0 0 24 24" class="edit-icon" fill="currentColor">
                    <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z" />
                </svg>
            </button>
            <img src="~/images/profile.jpg" alt="Profile" class="profile-img" />
        </div>
    </div>

    <!-- Separator -->
    <div class="dashboard-separator"></div>

    <!-- Recents -->
    <div class="recents-section">
        <h2 class="recents-title">Recents:</h2>
        <div class="recents-list">
            <div class="recent-card">
                <div class="recent-left">
                    <img src="~/images/project-icon.png" class="project-icon" alt="Project" />
                    <span class="project-name">Project Alpha</span>
                </div>
                <div class="recent-center">Meeting from yesterday at 12:45</div>
                <div class="recent-right">
                    <img src="~/images/meeting-icon.png" alt="Meeting" class="recent-icon" />
                </div>
            </div>

            <div class="recent-card">
                <div class="recent-left">
                    <img src="~/images/project-icon.png" class="project-icon" alt="Project" />
                    <span class="project-name">Project Beta</span>
                </div>
                <div class="recent-center">Summary done</div>
                <div class="recent-right">
                    <img src="~/images/document-icon.png" alt="Document" class="recent-icon" />
                </div>
            </div>
        </div>
    </div>
</section>


